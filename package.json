{
  "name": "keycloak-test",
  "version": "1.0.0",
  "description": "Aplicación con Keycloak (API + sync usuarios)",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --ignore-watch node_modules --ignore-watch tsconfig.json --ignore-watch dist src/index.ts",
    "dev:once": "ts-node src/index.ts",
    "sync-users": "node dist/scripts/sync-keycloak-users.js",
    "sync-users-dry-run": "node dist/scripts/sync-keycloak-users.js --dry-run",
    "delete-old-users": "node dist/scripts/sync-keycloak-users.js --delete-old"
  },
  "keywords": [
    "keycloak",
    "authentication",
    "oauth"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/node-cron": "^3.0.11",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "keycloak-connect": "^24.0.0",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.17.10",
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.0"
  }
}